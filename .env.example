# ─────────────────────────────────────────────────────────────────────────────
# API Tester — Docker Compose environment
#
#   cp .env.example .env
#   # fill in JWT_SECRET and OPENAI_API_KEY, then:
#   docker compose up --build
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=apiuser
POSTGRES_PASSWORD=apipass          # change in production
POSTGRES_DB=apitester

# ── JWT (required) ────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ── OpenAI (required for AI analysis) ────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=API Tester
DEBUG=true
BCRYPT_ROUNDS=12
CORS_ORIGINS=["http://localhost:3000"]
RATE_LIMIT_ENABLED=true

# ── Frontend (browser-visible — baked into the Next.js build at prod) ─────────
NEXT_PUBLIC_API_URL=http://localhost:8000
